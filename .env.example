# Copy to .env and fill in. Never commit .env (gitignored).

# === Content generation ===
ANTHROPIC_API_KEY=sk-ant-...

# === Images (free, real photos) ===
PEXELS_API_KEY=

# === Optional: web research ===
PERPLEXITY_API_KEY=

# === Per-site Vercel deploy hooks ===
# Project Settings → Git → Deploy Hooks
VERCEL_HOOK_SLEEPUPGRADEHUB=
VERCEL_HOOK_TRADINGHUB=
VERCEL_HOOK_AITOOLSEDGE=
VERCEL_HOOK_CODESTACKHUB=

# === IndexNow (Bing/Yandex/etc instant indexing) ===
INDEXNOW_KEY=

# === GitHub (for programmatic commits if needed) ===
GITHUB_OWNER=daperk
GITHUB_TOKEN=
